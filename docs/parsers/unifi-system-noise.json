    }
  ],
  "ignoreIfContaining": [
    "hppe_",
    "nss-dp ",
    "ubios-udapi-server",
    "ubnt-dpi",
    "dpi-flow-stats",
    "dnsAdBlock",
    "ubnt-netmon",
    "stahtd",
    "wevent",
    "libubnt",
    "mcad",
    "hostapd",
    "dnsmasq"
