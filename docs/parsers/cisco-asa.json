{
	"name": "Cisco ASA",
	"priority": 100,
	"parserClass": "CiscoAsaParser",
	"parserConfig": null,
	"rules": [
		{
			"type": "ContainsAny",
			"values": [
				"%ASA-",
				"%FWSM-",
				"%PIX-"
			]
		},
		{
			"type": "MustNotContain",
			"values": [
				"CEF:"
			]
		}
	],
	"ignoreIfContaining": [
		": AAA ",
		"%ASA-6-305011",
		"%ASA-6-305012",
		"-111",
		"-713",
		"-715",
		"-716",
		"-722",
		"-750",
		"-751"
	]
}