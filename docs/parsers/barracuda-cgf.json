{
  "name": "Barracuda CloudGen Firewall",
  "priority": 94,
  "parserClass": "BarracudaCgfParser",
  "parserConfig": null,
  "rules": [
    { "type": "ContainsAll", "values": [ "box_Firewall_Activity:" ] },
